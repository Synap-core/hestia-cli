{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "../lib/types/index.js": ["./src/lib/types/index.ts"],
      "../../lib/types/index.js": ["./src/lib/types/index.ts"],
      "../../../lib/types/index.js": ["./src/lib/types/index.ts"],
      "../../../../lib/types/index.js": ["./src/lib/types/index.ts"],
      "../lib/utils/index.js": ["./src/lib/utils/index.ts"],
      "../../lib/utils/index.js": ["./src/lib/utils/index.ts"],
      "../../../lib/utils/index.js": ["./src/lib/utils/index.ts"],
      "../lib/validator.js": ["./src/lib/validator.ts"],
      "../../lib/validator.js": ["./src/lib/validator.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}