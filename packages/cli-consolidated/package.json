{
  "name": "@hestia/cli",
  "version": "0.1.0",
  "description": "Sovereign AI infrastructure management CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hestia": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@gitlawb/openclaude": "^0.1.8",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "eventemitter3": "^5.0.1",
    "execa": "^9.0.0",
    "inquirer": "^9.3.8",
    "js-yaml": "^4.1.0",
    "listr2": "^8.2.1",
    "ora": "^8.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "keywords": [
    "hestia",
    "synap",
    "ai",
    "infrastructure",
    "cli"
  ],
  "author": "Synap",
  "license": "MIT"
}