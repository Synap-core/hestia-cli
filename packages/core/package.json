{
  "name": "@hestia/cli",
  "version": "0.1.0",
  "description": "Sovereign AI infrastructure management CLI",
  "type": "module",
  "main": "./dist/hestia.js",
  "bin": {
    "hestia": "./dist/hestia.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "test:integration": "node dist/hestia.js test:integration",
    "test:e2e": "node dist/hestia.js test:e2e",
    "test:smoke": "node dist/hestia.js test:smoke",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=json",
    "validate": "node dist/hestia.js validate",
    "validate:production": "node dist/hestia.js validate:production",
    "health": "node dist/hestia.js health",
    "health:watch": "node dist/hestia.js health:watch",
    "verify": "bash ../../verify.sh",
    "recovery:backup": "node dist/hestia.js recovery:backup --auto",
    "recovery:diagnose": "node dist/hestia.js recovery:diagnose"
  },
  "dependencies": {
    "@gitlawb/openclaude": "^0.1.8",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "eventemitter3": "^5.0.1",
    "execa": "^9.0.0",
    "inquirer": "^9.2.20",
    "js-yaml": "^4.1.0",
    "listr2": "^8.2.1",
    "ora": "^8.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "hestia",
    "synap",
    "ai",
    "infrastructure",
    "cli"
  ],
  "author": "Synap",
  "license": "MIT"
}
