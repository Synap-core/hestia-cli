{
  "name": "hestia",
  "version": "0.1.0",
  "description": "Hestia - Entity Creation System",
  "private": true,
  "workspaces": [
    "packages/@hestia/*",
    "packages/hestia-cli",
    "packages/cli-consolidated"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "build:new": "pnpm --filter @hestia/* --filter hestia-cli build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "cli": "pnpm --filter hestia-cli",
    "validate": "pnpm --filter @hestia/cli validate",
    "verify": "bash verify.sh"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "hestia",
    "synap",
    "ai",
    "infrastructure",
    "cli",
    "entity"
  ],
  "author": "Synap",
  "license": "MIT"
}
